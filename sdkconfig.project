# ============================================================================
# CPAP Data Uploader — SDK Configuration Reference
# ============================================================================
#
# This file is a HUMAN-READABLE REFERENCE for our custom SDK settings.
# It is NOT used by the build system.
#
# The actual build settings live in platformio.ini under "custom_sdkconfig".
# The pioarduino hybrid compile merges those entries with the Arduino base
# sdkconfig and writes the result to "sdkconfig.defaults" (a build artifact,
# gitignored, overwritten every build).
#
# This file exists so developers can understand WHY each setting was chosen
# without wading through platformio.ini's terse key=value format.
# ============================================================================

# ── Power management ─────────────────────────────────────────────────────────
# Enable the ESP-IDF power management framework. Required for DFS (Dynamic
# Frequency Scaling) and automatic light-sleep. Without this, esp_pm_configure()
# returns ESP_ERR_NOT_SUPPORTED.
CONFIG_PM_ENABLE=y

# ── Tickless idle ────────────────────────────────────────────────────────────
# Required for auto light-sleep. When all FreeRTOS tasks are idle for longer
# than IDLE_TIME_BEFORE_SLEEP ticks, and all PM locks are released, the CPU
# enters light-sleep automatically.
#
# The original GPIO wakeup conflict with PCNT on CS_SENSE (GPIO 33) is resolved
# by suspending the PCNT unit in IDLE/COOLDOWN states (releasing its PM lock)
# and relying on FreeRTOS tickless idle for periodic timer-based wakeup.
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y
CONFIG_FREERTOS_IDLE_TIME_BEFORE_SLEEP=3

# ── Core dump to flash ──────────────────────────────────────────────────────
# Save panic backtraces to the coredump partition (64KB at 0x3F0000).
# Read with: espcoredump.py info_corefile -t elf <firmware.elf>
# ELF format gives the richest backtrace info including task stacks.
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
CONFIG_ESP_COREDUMP_DATA_FORMAT_ELF=y
CONFIG_ESP_COREDUMP_CHECKSUM_CRC32=y

# ── Bluetooth removal ───────────────────────────────────────────────────────
# Compile-time removal of the entire Bluetooth stack. Saves ~60KB flash and
# prevents BT task creation. The CPAP uploader has no BT functionality.
CONFIG_BT_ENABLED=n

# ── FreeRTOS tick rate ───────────────────────────────────────────────────────
# Arduino ESP32 CMakeLists.txt (~line 405) enforces 1000 Hz. Cannot be
# overridden — delay(), millis(), micros() depend on it. Setting it here
# explicitly to document the constraint.
CONFIG_FREERTOS_HZ=1000

# ── WiFi PHY TX power cap ───────────────────────────────────────────────────
# Cap PHY-level TX power at 10 dBm (minimum allowed by Kconfig, range 10-20).
# Reduces transmit current spikes. Runtime WiFi.setTxPower() can go lower
# (down to WIFI_POWER_MINUS_1dBm / -1 dBm) for further savings.
CONFIG_ESP_PHY_MAX_WIFI_TX_POWER=10

# ── LWIP / WiFi buffer tuning ───────────────────────────────────────────────
# Reduced from defaults to save heap. These values were validated during the
# replatform and handle our typical upload traffic (HTTP/TLS + SMB).
CONFIG_ESP32_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_LWIP_PBUF_POOL_SIZE=16
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=32
CONFIG_LWIP_TCP_RECVMBOX_SIZE=8
CONFIG_LWIP_UDP_RECVMBOX_SIZE=6

# ── Brownout detector threshold ─────────────────────────────────────────────
# Use the default brownout level 0 (~2.43V). Level 7 (~2.74V) was tested but
# triggered too many resets on power-constrained CPAP hardware. Level 0 gives
# the widest voltage headroom while still protecting against deep rail collapse.
# Users with severe brownout issues can set BROWNOUT_DETECT=OFF in config.txt
# to disable the detector entirely (at their own risk).
CONFIG_ESP32_BROWNOUT_DET_LVL_SEL_0=y

# ── mbedTLS: struct-safe cipher removal ─────────────────────────────────────
# The hybrid compile recompiles IDF libs (incl. mbedTLS) but NOT the Arduino
# framework (WiFiClientSecure). Options that change struct sizes are FORBIDDEN:
#   KEEP_PEER_CERTIFICATE, SESSION_TICKETS, RENEGOTIATION, DTLS options,
#   ASYMMETRIC_CONTENT_LEN, VARIABLE_BUFFER_LENGTH
# However, cipher algorithm removal is SAFE — it only removes code/ciphersuites,
# not struct fields. Removing ChaCha20/Poly1305 forces AES-GCM negotiation
# which uses the ESP32's hardware AES accelerator (faster + lower power).
CONFIG_MBEDTLS_CHACHA20_C=n
CONFIG_MBEDTLS_POLY1305_C=n
CONFIG_MBEDTLS_CHACHAPOLY_C=n

# ── WiFi sleep optimizations (REMOVED) ───────────────────────────────────────
# CONFIG_ESP_WIFI_SLP_IRAM_OPT=y was removed to recover ~2-4KB DRAM.
# Its sub-select PM_SLP_DEFAULT_PARAMS_OPT adds sleep parameter tables to DRAM,
# reducing the initial heap pool. After TLS handshake fragmentation, this pushed
# max_alloc below the ~38KB threshold needed for subsequent TLS connects.
# The main power savings (light-sleep, tickless idle, PCNT suspend/resume) are
# retained without this option. WiFi modem-sleep still works at default timing.
