# ESP-IDF SDK configuration overrides
# Applied during build via board_build.sdkconfig in platformio.ini.
#
# lwIP tuning — reducing network resource exhaustion under concurrent load
# (SMB upload + SleepHQ TLS streaming + web server all sharing the same pbuf pool).
#
# Default CONFIG_LWIP_PBUF_POOL_SIZE is 10. Each pbuf is ~1.6 KB, so 32 pbufs
# costs ~35 KB of additional DRAM but prevents EAGAIN exhaustion when the web
# server holds multiple open connections during an active upload session.

CONFIG_LWIP_PBUF_POOL_SIZE=16

# Increase the TCP/IP thread receive mailbox so bursts of incoming packets
# from concurrent connections are not dropped before lwIP can process them.
# Default is 32; doubling reduces packet loss under rapid browser refresh.
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=32

# Larger per-socket receive mailboxes reduce the chance that a slow SleepHQ
# TLS write stalls the lwIP receive path for other sockets.
CONFIG_LWIP_TCP_RECVMBOX_SIZE=8
CONFIG_LWIP_UDP_RECVMBOX_SIZE=6

# Reduce WiFi static RX buffers (default 8 → 6, saves ~3KB)
CONFIG_ESP32_WIFI_STATIC_RX_BUFFER_NUM=6

# ── Power management ─────────────────────────────────────────────────────────
# Disable Bluetooth entirely — firmware is WiFi-only.
# Saves ~30 KB DRAM and eliminates BT-related leakage current.
CONFIG_BT_ENABLED=n

# Cap the PHY-level maximum WiFi TX power at 10 dBm (Kconfig minimum).
# Prevents peak current spikes during RF calibration and association even
# before runtime code has a chance to call esp_wifi_set_max_tx_power().
# The Kconfig range is 10-20; 10 is the absolute floor.
CONFIG_ESP_PHY_MAX_WIFI_TX_POWER=10

# Enable ESP-IDF power management framework (required for DFS).
# Allows automatic CPU frequency scaling when tasks are idle.
CONFIG_PM_ENABLE=y

# FreeRTOS tick rate — 100 Hz is sufficient when CPU is locked at 80 MHz (no DFS).
# No firmware operation requires sub-10 ms scheduling (PCNT is hardware, WiFi has
# its own timers). Reduces ISR overhead by 90% compared to 1000 Hz.
CONFIG_FREERTOS_HZ=100

# ── Tickless idle (required for auto light-sleep) ────────────────────────────
# Suppresses tick ISRs during idle, allowing the CPU to sleep for longer periods
# between WiFi DTIM intervals. The system wakes on the next scheduled event.
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y
CONFIG_FREERTOS_IDLE_TIME_BEFORE_SLEEP=3

# ── Brownout detector threshold ─────────────────────────────────────────────
# Use the default brownout level 0 (~2.43V). Level 7 (~2.74V) was tested but
# triggered too many resets on power-constrained CPAP hardware. Level 0 gives
# the widest voltage headroom while still protecting against deep rail collapse.
# Users with severe brownout issues can set BROWNOUT_DETECT=OFF in config.txt
# to disable the detector entirely (at their own risk).
CONFIG_ESP32_BROWNOUT_DET_LVL_SEL_0=y

# ── TLS cipher optimization ──────────────────────────────────────────────────
# Disable ChaCha20-Poly1305 — no hardware acceleration on ESP32.
# ChaCha20 is 3-5x slower than HW AES on ESP32, generating unnecessary CPU load
# and DFS transitions during TLS. Forces mbedtls to negotiate AES-GCM ciphers
# which use the ESP32's dedicated AES and SHA hardware accelerators.
CONFIG_MBEDTLS_CHACHA20_C=n
CONFIG_MBEDTLS_CHACHAPOLY_C=n

# Disable AES-256 — force AES-128 only (fewer rounds, less computation).
# SleepHQ supports AES-128-GCM-SHA256 which provides adequate 128-bit security.
# If SleepHQ ever drops AES-128 support, re-enable by changing to =y.
CONFIG_MBEDTLS_AES_256_C=n

# ── TLS heap fragmentation reduction ────────────────────────────────────────
# NOTE: These mbedTLS buffer options only take effect if the Arduino-ESP32
# framework recompiles mbedTLS from source.  Pre-compiled .a libraries in
# the stock framework may ignore them.  Verify by checking max_alloc delta
# before and after enabling these options.

# Asymmetric record buffers: keep 16KB IN (server can send large TLS records)
# but shrink OUT to 4KB (our HTTP requests/multipart headers are small).
# Saves 12KB of persistent heap per TLS connection.
CONFIG_MBEDTLS_ASYMMETRIC_CONTENT_LEN=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096

# Allow mbedTLS to shrink I/O buffers after handshake to match the negotiated
# maximum record size.  Can reclaim up to 12KB if the server negotiates a
# smaller max_fragment_length.
CONFIG_MBEDTLS_SSL_VARIABLE_BUFFER_LENGTH=y

# Don't keep the peer certificate chain in memory after verification.
# Saves 2-4KB per connection — only needed during handshake.
CONFIG_MBEDTLS_SSL_KEEP_PEER_CERTIFICATE=n

# ── Disable unused TLS features ─────────────────────────────────────────────
# These reduce code size and attack surface. Session tickets and renegotiation
# are server-initiated features we never use. DTLS is for UDP (we only use TCP).
CONFIG_MBEDTLS_SSL_SESSION_TICKETS=n
CONFIG_MBEDTLS_SSL_RENEGOTIATION=n
CONFIG_MBEDTLS_SSL_DTLS_HELLO_VERIFY=n
CONFIG_MBEDTLS_SSL_DTLS_CONNECTION_ID=n
